{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Soundfeed.Api.Middlewares": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Spotify": {
    "ClientId": "",
    "ClientSecret": "",
    "BaseUrl": "https://api.spotify.com/v1",
    "TokenUrl": "https://accounts.spotify.com/api/token"
  },
  "Jobs": {
    "ReleaseSyncJob": "0 0 0/4 ? * * *",
    "InactiveUserJob": "0 0 0 * * ?"
  },
  "AllowedHosts": "*",
  "CookieSettings": {
    "SecretKey": ""
  },
  "AllowedOrigins": ""
}
