# postgres
POSTGRES_DB=soundfeed
POSTGRES_USER=soundfeed
POSTGRES_PASSWORD=

# spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# 32 char secret key
COOKIE_SECRET_KEY=

# set this to your domain, e.g. https://soundfeed.example.com
ALLOWED_ORIGINS=https://example.com
ALLOWED_HOSTS=*

# contact email shown in the frontend
VITE_CONTACT_EMAIL=

# release sync job (every 4 hours)
RELEASE_SYNC_JOB=0 0 0/4 ? * * *

# sendgrid email digest (monday 8am)
EMAIL_JOB=0 0 8 ? * MON *
EMAIL_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_FEED_URL=
EMAIL_LOGO_URL=